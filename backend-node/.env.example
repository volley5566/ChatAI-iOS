DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
PORT=8000

# Phase 5: SQLite 数据库文件路径
# Prisma 路径相对的是 prisma/schema.prisma 所在目录;"file:./dev.db" 表示 prisma/dev.db
# LangGraph checkpointer 也用同一个文件(在 db/ 模块里我们会用绝对路径打开它)
DATABASE_URL="file:./dev.db"

# LangChain RAG
EMBEDDINGS_PROVIDER=local-keyword
RAG_TOP_K=5
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=160
RAG_MIN_SIMILARITY=0.08

# LangChain Agent / 工具 / 流式（第三阶段）
# Agent 内部最多迭代多少步（无论模型如何决策都不会超过）
# 带满整套 middleware 时单轮工具调用大约消耗 12~15 步，默认 20 留余量
AGENT_RECURSION_LIMIT=20
# modelRetryMiddleware：单次 model node 失败时的重试次数（指数退避）
AGENT_MODEL_RETRY_MAX_ATTEMPTS=2
# 整次 Agent 最多调用模型多少次（成本兜底）
AGENT_MODEL_CALL_LIMIT=6
# ChatDeepSeek HTTP 层 maxRetries：单次 fetch 失败时的重试次数
CHAT_MODEL_HTTP_MAX_RETRIES=2
# 单个 MCP 工具最大执行时间（毫秒）
TOOL_EXECUTION_TIMEOUT_MS=8000

# Phase 4 — LangGraph 切换开关
# false（默认）：Agent Runner 走 Phase 3 createAgent
# true：走 Phase 4 手写 StateGraph
# 改完需要重启 backend 生效
USE_LANGGRAPH=false

# Phase 12 — 跨对话长期记忆:读取(recall)
# 只在 USE_LANGGRAPH=true 路径生效(recall 节点挂在 StateGraph 上)
# MEMORY_RECALL_ENABLED=false（默认）：模型看不到跨对话记忆,行为同 Phase 11
# 设成 true：每次新请求按当前问题语义检索该用户的长期记忆,注入 SystemMessage
# MEMORY_RECALL_ENABLED=true
# 每次最多注入几条记忆
MEMORY_RECALL_TOP_K=5
# 相似度下限(0..1),低于此分判为无关、不注入;nomic-embed-text 基线偏高,默认 0.5 偏宽松
MEMORY_RECALL_MIN_SCORE=0.5

# Phase 12 — 跨对话长期记忆:写入(write)
# MEMORY_WRITE_ENABLED=false（默认）：不自动写记忆(只能用 memory:debug 手动灌)
# 设成 true：每轮对话结束后后台调一次 LLM,提炼"关于用户的稳定信息"去重入库(fire-and-forget)
# MEMORY_WRITE_ENABLED=true
# 写入去重阈值(0..1):新记忆和已有记忆相似度 ≥ 此值就更新旧的而非新增;默认 0.85 偏高(只合并近乎重复的)
MEMORY_WRITE_DEDUP_THRESHOLD=0.85

# LangSmith trace（可选）
# 配齐这两项后所有 Chain / Model / Tool / Agent 调用都会自动上报到 smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=ai-ios-chat-demo
